      "closestHeading": "Tables",
      "pageNumber": 3
    }
  },
  {
    "text": "Cedar University 110 103 +7",
    "metadata": {
      "sourceType": "pdf",
      "closestHeading": "Tables",
      "pageNumber": 3
    }
  },
  {
    "text": "Oak Institute 202 210 -8",
    "metadata": {
      "sourceType": "pdf",
      "closestHeading": "Tables",
      "pageNumber": 3
    }
  },
  {
    "text": "Graduate",
    "metadata": {
